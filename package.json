{
  "name": "trading-keys",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "better-sqlite3": "^12.2.0",
    "cheerio": "^1.1.2",
    "cookies-next": "^4.2.1",
    "ioredis": "^5.4.1",
    "lightweight-charts": "^5.0.9",
    "next": "^13.5.11",
    "puppeteer": "^24.15.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "styled-components": "^5.1.34",
    "typescript": "^5.8.3",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "redis-windows": "redis-server C:/Documents/trading-keys-next/redis.windows.conf",
    "redis-ubuntu": "redis-server /etc/redis/redis.conf",
    "build": "next build",
    "start": "next start -p 4000",
    "build:threads": "tsc -p tsconfig.worker.json",
    "run:live": "npm run build:threads && tsx runner/startRunner.ts --mode=live",
    "run:demo": "npm run build:threads && tsx runner/startRunner.ts --mode=demo",
    "check:automation": "npm run build:threads && tsx runner/startRunner.ts --mode=demo --check",
    "test:strategy": "tsx --test tests/goldilocksStrategy.test.ts tests/priceStreamManager.test.ts",
    "start:prod": "npm run run:demo"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/next": "^9.0.0",
    "@types/node": "^24.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/styled-components": "^5.1.34",
    "babel-plugin-styled-components": "^2.1.4",
    "concurrently": "^8.2.2",
    "tsx": "^4.19.4"
  }
}
